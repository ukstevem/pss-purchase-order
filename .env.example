# pss-purchase-order — environment variables
# Copy to .env and fill in for local dev. NEVER commit .env.
# Shared secrets (Supabase, APP_URL) are canonical in platform-portal/.env
# and are picked up at deploy time via env_file: ../platform-portal/.env.

# --- Supabase (browser client; build-time NEXT_PUBLIC_* need --build-arg) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-side admin; RLS bypass — server actions/route handlers only) ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- Gateway origin (OAuth redirect + cross-app links) ---
NEXT_PUBLIC_APP_URL=

# --- App ---
NEXT_PUBLIC_BASE_PATH=/purchase-order

# --- Dev only: email/password sign-in for the local Supabase clone ---
# Set to 1 ONLY in local/.env (git-ignored) when developing against
# 10.0.0.85; never in production builds. See docker-compose.local.yml.
NEXT_PUBLIC_ALLOW_PASSWORD_AUTH=

# --- Stage-2 write gate (runtime) ---
# "1" arms create/edit/expediting/accounts writes. Leave unset for
# read-only. Enforced in every server action, not just the UI.
PO_WRITES_ENABLED=

# --- PDF pipeline (runtime, server-only; bead 9bq.31) ---
# pss-pdf-service: ephemeral previews. Prod: http://10.0.0.74:8017
PDF_SERVICE_URL=
PDF_SERVICE_API_KEY=
# pss-document-service: render+file at issue time. Prod: http://10.0.0.74:3000
DOC_SERVICE_URL=
DOC_SERVICE_API_KEY=
# Browser-reachable base for filed-document links (may differ from the
# server-side URL when the app runs in a container)
DOC_SERVICE_PUBLIC_URL=
# ISO 61355 description for filed POs (53 = ORDER, subclass CD)
PO_ISO_DESCRIPTION_ID=53

# --- Microsoft Graph / Outlook draft emails (bead 9bq.7) ---
# Client-credentials app; drafts are created (never sent) in the shared
# mailbox with the filed PDF attached. EMAIL_DRAFT_ON_PO must be "1" to
# enable (default OFF — deliberate deviation from legacy's default-on).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_OUTLOOK_MAILBOX=
EMAIL_DRAFT_ON_PO=

# --- PO PDF archive target (legacy: SMB share mounted on the Pi — TBC) ---
NETWORK_ARCHIVE_DIR=

# --- Image tag pin for rollback (docker-compose.app.yml) ---
IMAGE_TAG=latest
